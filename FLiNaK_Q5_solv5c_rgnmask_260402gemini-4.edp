// ============================================================
// FLiNaK_Q5_DualWindow_Final_20260402.edp
// 2画面独立表示（時間表示・WindowIndex固定版）
// ============================================================

// --- 1. 幾何形状 & メッシュ ---
real w = 0.25; real H = 0.8; real S = 0.1; real H1 = 0.6;
real d = 0.15; real w1 = 0.03; real rpipe = 0.02; real d2 = 0.01;

border C1(t=rpipe, w-d2) {x=t; y=d2; label=1;}
border C2(t=d2, H){x=w-d2; y=t; label=2;}
border C3(t=w-d2,rpipe){x=t; y=H; label=3;}
border Cpipe(t=H,d2){x=rpipe; y=t; label=12;}
border D1(t=0, w1) {x=d+t; y=S; label=20;}
border D2(t=S, S+H1) {x=d+w1; y=t; label=20;}
border D3(t=0, pi) {x=d+w1/2.0 + (w1/2.0)*cos(t); y=S+H1 + (w1/2.0)*sin(t); label=20;}
border D4(t=S+H1, S) {x=d; y=t; label=20;}
border E1(t=d2,0){x=rpipe; y=t; label=30;}
border E2(t=rpipe,w){x=t; y=0; label=30;}
border E3(t=0,H){x=w; y=t; label=30;}
border E4(t=w,w-d2){x=t; y=H; label=30;}

mesh Th = buildmesh(C1(20)+C2(80)+C3(20)+Cpipe(80)+D1(20)+D2(60)+D3(40)+D4(60)+E1(10)+E2(30)+E3(40)+E4(10));

// メッシュ確認（もし不要ならここをコメントアウトすると、最初のウィンドウが出ません）
// plot(Th, wait=0, WindowIndex=0); 

// --- 2. 空間 & 変数定義 ---
fespace Ph(Th, P0); fespace Vh(Th, P2); fespace Qh(Th, P1); 
Vh u=0, v=0, uu, vv, up, vp;
Qh p=0, pp, r=500.0+273.15, rr, rp; 
Ph kappa, fQ, fP, mask;
mask = (region == Th(rpipe+0.01, H/2.0).region) ? 1.0 : 0.0;

real kelvin=273.15, Tref=500+kelvin, rho=2.02e3, mu=2.9e-3, nu=mu/rho, Cp=1.883e3, rhoCp=rho*Cp;
kappa = 0.92; fQ = ( (x>=rpipe && x<d) && (y>=S && y<=S+H1) ) ? 50.0e3 : 0.0;
fP = ( (x>=rpipe && x<d) && (y>=S && y<=S+S*0.1) ) ? 0.02 : 0.0;

// --- 3. 時間ループ ---
real Tmax=100.0, dt=0.05; int n=0;

for (real t=0; t<Tmax; t+=dt){
    u = u * mask; v = v * mask; 
    up=u; vp=v; rp=r;

    solve NS([u,v,p], [uu,vv,pp], solver=Crout, init=n) =
        int2d(Th)( x*((u*uu+v*vv)/dt + nu*(dx(u)*dx(uu)+dy(u)*dy(uu)+dx(v)*dx(vv)+dy(v)*dy(vv)) - p*(dx(uu)+dy(vv)+uu/x) + pp*(dx(u)+dy(v)+u/x) + p*pp*1e-9) )
        - int2d(Th)( x*((convect([up,vp],-dt,up)*uu + convect([up,vp],-dt,vp)*vv)/dt + 2.0e-4*9.81*(r-Tref)*vv + fP*vv/dt) )
        + on(1,2,3,12,20, u=0, v=0);

    solve thermal(r,rr, solver=Crout, init=n) =
        int2d(Th)( x*(r*rr/dt + (kappa/rhoCp)*(dx(r)*dx(rr)+dy(r)*dy(rr))) )
        - int2d(Th)( x*(convect([up,vp],-dt,rp)*rr/dt + (fQ/rhoCp)*rr) )
        + on(30, r=Tref);

    if (n % 10 == 0) {
        Vh TempC = r - kelvin;
        
        // --- Window 0: 温度 (タイトルに時間を追加) ---
        plot(TempC, fill=true, value=true, nbiso=30, 
             cmm="Temperature [C] (Time = "+t+"s)", wait=false, WindowIndex=0);
        
        // --- Window 1: 速度ベクトル (タイトルに時間を追加) ---
        plot([u, v], value=true, coef=0.1, 
             cmm="Velocity Field [m/s] (Time = "+t+"s)", wait=false, WindowIndex=1);
        
        cout << "Step: " << n << " Time: " << t << "s" << endl;
    }
    n++;
}